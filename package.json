{
  "name": "agentiq",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/interfaces/index.ts",
    "dev": "concurrently \"npm run forecast-agent\" \"npm start\"",
    "init-db": "cd ../agentiq-mcp-server && npm run init-db",
    "seed": "cd ../agentiq-mcp-server && npm run seed",
    "daily-seed": "cd ../agentiq-mcp-server && npm run daily-seed",
    "clear-cache": "cd ../agentiq-mcp-server && npm run clear-cache",
    "voice:generate": "npx tsx src/voice/generateVoices.ts",
    "interactive": "tsx src/interfaces/interactive.ts",
    "bot": "tsx src/interfaces/telegramBot.ts",
    "voice": "tsx src/interfaces/alfred.ts",
    "forecast-agent": "cd ../forecast-agent && npm run dev",
    "anomaly": "tsx src/services/anomalyService.ts",
    "alfred": "concurrently \"npm run forecast-agent\" \"npm run voice\""
  },
