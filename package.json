{
  "name": "biagent",
  "version": "1.0.0",
  "main": "index.js",
  "workspaces": [
    "app/common",
    "app/infra/local",
    "app/analytics",
    "app/orders",
    "app/catalog",
    "app/customers",
    "app/reviews",
    "app/backoffice",
    "app/knowledge",
    "app/outbox-worker"
  ],
  "scripts": {
    "start": "tsx biagent/interfaces/index.ts",
    "interactive": "tsx biagent/interfaces/interactive.ts",
    "dev": "tsx biagent/interfaces/interactive.ts",
    "bot": "tsx biagent/interfaces/telegramBot.ts",
    "voice": "tsx biagent/interfaces/alfred.ts",
    "voice:generate": "npx tsx biagent/alfred/generateVoices.ts",
    "knowledge": "tsx app/knowledge/src/index.ts",
    "ingest": "tsx app/knowledge/src/scripts/ingest.ts",
    "svc:orders": "tsx app/orders/src/index.ts",
    "svc:catalog": "tsx app/catalog/src/index.ts",
    "svc:customers": "tsx app/customers/src/index.ts",
    "svc:reviews": "tsx app/reviews/src/index.ts",
    "svc:backoffice": "tsx app/backoffice/src/index.ts",
    "analytics": "tsx app/analytics/src/index.ts",
    "outbox-worker": "tsx app/outbox-worker/src/index.ts",
    "demo:infra": "docker compose up -d",
    "demo:init": "tsx app/infra/local/init-demo.ts",
    "demo": "concurrently --names \"knowledge,analytics\" -c \"green,blue\" \"npm run knowledge\" \"npm run analytics\"",
    "seed-warehouse": "tsx app/infra/local/clickhouse/seed-warehouse.ts"
  },
